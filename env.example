# Copy this to .env and fill in if you want to override AWS defaults.
# The proxy reads credentials from ~/.aws/config automatically via boto3,
# so these are only needed if you want to override that.

# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here
# AWS_REGION=us-east-1

# Proxy port (default: 8080)
# PORT=8080

# Logging level: DEBUG | INFO | WARNING | ERROR (default: INFO)
# LOG_LEVEL=INFO

# Max tokens used in /v1/test/* endpoints to keep costs minimal (default: 1)
# TEST_MAX_TOKENS=1
